# Copy this file to .env and fill in your values
# The install script will automatically load .env if it exists

# GitHub Personal Access Token
# Required for: GitHub MCP server (OpenCode)
# Create at: https://github.com/settings/tokens
GITHUB_PAT=ghp_...

# Context7 API Key
# Required for: Context7 MCP server (OpenCode, Codex, Cursor)
# Get at: https://context7.com/settings
CONTEXT7_API_KEY=...

# Linear API Key
# Required for: Linear MCP server (OpenCode)
# Create at: https://linear.app/settings/api
LINEAR_API_KEY=lin_api_...
